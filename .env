APP_NAME="ML Predictor Pro"
APP_VERSION="1.0.0"
MAX_CSV_ROWS=1461
RATE_LIMIT_PER_IP=60
RATE_LIMIT_WINDOW=3600
DAILY_TOKEN_LIMIT=20
TOKEN_WINDOW=86400

PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
CLEANING_PRICE=1.00

# PostgreSQL - Render fournit DATABASE_URL automatiquement avec le add-on Managed PostgreSQL
# Si tu utilises un add-on Render, ne definit pas DATABASE_URL ici, Render le fait pour toi
DATABASE_URL=

# JWT Auth - CHANGE CES VALEURS EN PRODUCTION
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# SMTP Email (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=ML Predictor Pro
SMTP_FROM_EMAIL=

# Security - Render utilise HTTPS automatiquement
COOKIE_SECURE=true
COOKIE_DOMAIN=
CSRF_COOKIE_SECURE=true
